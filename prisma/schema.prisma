generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")        // pooler URL — use for all app queries
  directUrl = env("DIRECT_URL")          // non-pooled — used only by prisma migrate/db push
}

model User {
  id                    Int                  @id @default(autoincrement())
  name                  String?
  email                 String               @unique
  emailVerified         DateTime?
  image                 String?
  role                  String               @default("user")
  phoneNumber           String?
  phoneVerified         Boolean              @default(false)
  password              String?
  language              String               @default("en")
  notificationPrefs     String               @default("{\"email\":true,\"sms\":false,\"whatsapp\":false}")
  loyaltyPoints         Int                  @default(0)
  orders                Order[]
  repairTickets         RepairTicket[]
  reviews               Review[]
  accounts              Account[]
  sessions              Session[]
  notifications         Notification[]
  tradeIns              TradeIn[]
  marketplaceListings   MarketplaceListing[]
  wishlist              Wishlist[]
  loyaltyTransactions   LoyaltyTransaction[]
  stockAlerts           StockAlert[]
  priceAlerts           PriceAlert[]
  referralCode          String?              @unique
  referralsMade         Referral[]           @relation("referrer")
  referredBy            Referral?            @relation("referred")
  returns               Return[]
  savedAddresses        SavedAddress[]
  newsletterSub         Newsletter?
  verifiedBuyer         Boolean              @default(false)
  preOrders             PreOrder[]
  storeCredit           Int                  @default(0)
  loyaltyCard           LoyaltyCard?
  bio                   String               @default("")
  sellerStatus          String               @default("active")
  sellerSuspendedReason String               @default("")
  sellerSubscriptionExp DateTime?
  sellerFirstListingAt  DateTime?
  createdAt             DateTime             @default(now())
  mustChangePassword    Boolean              @default(false)
}

model Account {
  id                String  @id @default(cuid())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Product {
  id                Int         @id @default(autoincrement())
  name              String
  category          String
  description       String
  price             Int
  comparePrice      Int?
  images            String      @default("[]")
  colors            String      @default("[]")
  storageOptions    String      @default("[]")
  warrantyOptions   String      @default("[]")
  specs             String      @default("{}")
  stock             Int
  lowStockThreshold Int         @default(5)
  serialNumbers     String      @default("[]")
  colorStock        String      @default("{}")
  storageStock      String      @default("{}")
  subcategory       String?
  active            Boolean     @default(true)
  featured          Boolean     @default(false)
  brand             String?
  sku               String?
  weight            String?
  dimensions        String?
  tags              String      @default("[]")
  genuine           Boolean     @default(true)
  videoUrl          String      @default("")
  hasTvInstall      Boolean     @default(false)
  condition         String      @default("new")
  bundledWith       String      @default("[]")
  storagePrice      String      @default("{}")
  colorImages       String      @default("{}")
  flashSalePrice    Int?
  flashSaleEnd      DateTime?
  preOrder          Boolean   @default(false)
  preOrderDate      DateTime?
  preOrderDeposit   Int       @default(0)
  items             OrderItem[]
  reviews           Review[]
  wishlistItems     Wishlist[]
  stockAlerts       StockAlert[]
  priceAlerts       PriceAlert[]
  qaItems           ProductQA[]
  preOrders         PreOrder[]
  @@index([category])
  @@index([active, featured])
  @@index([active, category])
  @@index([active, stock])
  @@index([active, flashSaleEnd])
  @@index([active, price])
}

model Order {
  id               Int           @id @default(autoincrement())
  createdAt        DateTime      @default(now())
  total            Int
  discountAmount   Int           @default(0)
  couponCode       String?
  status           String        @default("pending")
  receiptUrl       String?
  adminConfirmed   Boolean       @default(false)
  paymentConfirmed Boolean       @default(false)
  billPrintable    Boolean       @default(false)
  paymentMethod    String?
  shippingName     String?
  shippingEmail    String?
  shippingPhone    String?
  shippingAddress  String?
  notes            String?
  user             User?         @relation(fields: [userId], references: [id])
  userId               Int?
  installmentPlan      String        @default("")
  installmentMonths    Int           @default(0)
  tvInstallation       Boolean       @default(false)
  tvInstallAddress     String        @default("")
  mpostAddress         String        @default("")
  deliveryStatus       String        @default("")
  deliveryTracking     String        @default("")
  currency             String        @default("USD")
  tradeInId            Int?
  customerConfirmed        Boolean       @default(false)
  customerConfirmedAt      DateTime?
  stripePaymentIntentId    String?
  deliverySlot             String        @default("")
  deliveryDate             String        @default("")
  adminNote                String        @default("")
  whatsappUpdates          Boolean       @default(false)
  guestEmail               String?
  cancelledAt              DateTime?
  cancelReason             String        @default("")
  deliveryFee              Int           @default(0)
  reviewRequestSent        Boolean       @default(false)
  items                    OrderItem[]
  repairTickets            RepairTicket[]
  returnRequest            Return?
  savedAddresses           SavedAddress[]
  @@index([userId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
}

model SavedAddress {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  label     String   @default("Home")
  name      String
  phone     String
  address   String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  orders    Order[]
  @@index([userId])
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  order     Order   @relation(fields: [orderId], references: [id])
  orderId   Int
  product   Product @relation(fields: [productId], references: [id])
  productId Int
  name      String
  price     Int
  quantity  Int
  color     String
  storage   String
  warranty  String
  serial    String
}

model Coupon {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  type        String   @default("percent")
  value       Int
  minOrder    Int      @default(0)
  maxUses     Int      @default(0)
  usedCount   Int      @default(0)
  active      Boolean  @default(true)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
}

model Review {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  product   Product  @relation(fields: [productId], references: [id])
  productId Int
  rating    Int
  title     String
  body      String
  images    String   @default("[]")
  verified  Boolean  @default(false)
  approved  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model RepairTicket {
  id              Int      @id @default(autoincrement())
  user            User     @relation(fields: [userId], references: [id])
  userId          Int
  order           Order?   @relation(fields: [orderId], references: [id])
  orderId         Int?
  productName     String
  issue           String
  description     String   @default("")
  status          String   @default("open")
  priority        String   @default("normal")
  adminNotes      String   @default("")
  contactMethod   String   @default("whatsapp")
  preferredTime   String   @default("")
  techPhone       String   @default("")
  deviceImages    String   @default("[]")
  quotedCost      Int      @default(0)
  quoteNotes      String   @default("")
  quoteStatus     String   @default("pending")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now())
}

model Notification {
  id        Int      @id @default(autoincrement())
  user      User?    @relation(fields: [userId], references: [id])
  userId    Int?
  type      String
  title     String
  body      String
  link      String   @default("")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  @@index([userId, read])
}

model SiteConfig {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model TradeIn {
  id           Int      @id @default(autoincrement())
  user         User     @relation(fields: [userId], references: [id])
  userId       Int
  productName  String
  brand        String   @default("")
  condition    String   @default("good")
  description  String   @default("")
  images       String   @default("[]")
  askingPrice  Int      @default(0)
  offeredPrice Int      @default(0)
  counterPrice Int      @default(0)
  finalPrice   Int      @default(0)
  status       String   @default("pending")
  adminNotes   String   @default("")
  userNotes    String   @default("")
  couponCode   String   @default("")
  orderId      Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now())
}

model MarketplaceListing {
  id          Int      @id @default(autoincrement())
  seller      User     @relation(fields: [sellerId], references: [id])
  sellerId    Int
  title       String
  description String
  price       Int
  category    String
  condition   String   @default("good")
  images      String   @default("[]")
  status      String   @default("pending")
  adminNotes  String   @default("")
  verified    Boolean  @default(false)
  views       Int      @default(0)
  phone       String   @default("")
  location    String   @default("")
  negotiable  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())
}

model Wishlist {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int
  createdAt DateTime @default(now())
  @@unique([userId, productId])
}

model LoyaltyTransaction {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  points    Int
  action    String   // 'earn' | 'redeem' | 'expire'
  reason    String   // 'purchase' | 'review' | 'referral' | 'manual'
  orderId   Int?
  createdAt DateTime @default(now())
  @@index([userId, createdAt(sort: Desc)])
}

model StockAlert {
  id        Int      @id @default(autoincrement())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int?
  email     String?
  phone     String?
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())
  @@index([productId, notified])
}

model PriceAlert {
  id        Int      @id @default(autoincrement())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int?
  email     String?
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())
  @@index([productId, notified])
}

model DeliveryZone {
  id            Int     @id @default(autoincrement())
  name          String
  fee           Int     @default(0)
  active        Boolean @default(true)
  sortOrder     Int     @default(0)
  estimatedDays Int     @default(1)
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int?
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  @@index([userId])
}

model SmsLog {
  id        Int      @id @default(autoincrement())
  to        String
  message   String
  status    String   @default("pending")
  provider  String   @default("africastalking")
  orderId   Int?
  createdAt DateTime @default(now())
}

model Newsletter {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  name       String?
  active     Boolean  @default(true)
  couponCode String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId     Int?     @unique
  createdAt  DateTime @default(now())
}

model Referral {
  id             Int      @id @default(autoincrement())
  referrer       User     @relation("referrer", fields: [referrerId], references: [id])
  referrerId     Int
  referredEmail  String
  referredUser   User?    @relation("referred", fields: [referredUserId], references: [id])
  referredUserId Int?     @unique
  code           String   @unique
  status         String   @default("pending")
  rewardGiven    Boolean  @default(false)
  createdAt      DateTime @default(now())
}

model Return {
  id           Int      @id @default(autoincrement())
  order        Order    @relation(fields: [orderId], references: [id])
  orderId      Int      @unique
  user         User?    @relation(fields: [userId], references: [id])
  userId       Int?
  reason       String
  description  String   @default("")
  images       String   @default("[]")
  status       String   @default("pending")
  adminNotes   String   @default("")
  refundAmount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now())
}

model AbandonedCart {
  id        Int      @id @default(autoincrement())
  userId    Int?     @unique
  email     String?
  items     String   @default("[]")
  emailSent Boolean  @default(false)
  updatedAt DateTime @default(now())
  createdAt DateTime @default(now())
}

model ProductQA {
  id        Int      @id @default(autoincrement())
  product   Product  @relation(fields: [productId], references: [id])
  productId Int
  question  String
  answer    String
  askedBy   String   @default("Anonymous")
  helpful   Int      @default(0)
  createdAt DateTime @default(now())
}

model PreOrder {
  id          Int      @id @default(autoincrement())
  product     Product  @relation(fields: [productId], references: [id])
  productId   Int
  user        User     @relation(fields: [userId], references: [id])
  userId      Int
  email       String
  name        String
  phone       String   @default("")
  depositPaid Int      @default(0)
  status      String   @default("pending")
  createdAt   DateTime @default(now())
}

model BulkQuote {
  id          Int      @id @default(autoincrement())
  companyName String
  contactName String
  email       String
  phone       String
  items       String   @default("")
  message     String   @default("")
  status      String   @default("pending")
  adminNotes  String   @default("")
  quotedTotal Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())
}

model LoyaltyCard {
  id          Int       @id @default(autoincrement())
  user        User      @relation(fields: [userId], references: [id])
  userId      Int       @unique
  cardNumber  String    @unique
  status      String    @default("pending")
  tier        String    @default("Bronze")
  points      Int       @default(0)
  approvedAt  DateTime?
  expiresAt   DateTime?
  adminNotes  String    @default("")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now())
}

model GiftCard {
  id         Int       @id @default(autoincrement())
  code       String    @unique
  amount     Int
  balance    Int
  buyerEmail String
  buyerName  String    @default("")
  toEmail    String?
  toName     String    @default("")
  message    String    @default("")
  redeemedBy Int?
  redeemedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
}

model PageView {
  id        Int      @id @default(autoincrement())
  path      String
  createdAt DateTime @default(now())

  @@index([path])
  @@index([createdAt])
}
