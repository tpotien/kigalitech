# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (local dev — file lives in the project root)
DATABASE_URL="file:./dev.db"

# ── NextAuth ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"

# ── Admin credentials (hardcoded fallback login) ──────────────────────────────
ADMIN_EMAIL="admin@kigalitech.com"
ADMIN_PASSWORD="admin123"

# ── OAuth providers (optional — leave blank to disable) ───────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_ID=""
GITHUB_SECRET=""

# ── Email (optional — for order confirmations) ────────────────────────────────
EMAIL_SERVER="smtp://user:pass@smtp.example.com:587"
EMAIL_FROM="KigaliTech <noreply@kigalitech.com>"

# ── Stripe (optional — for card payments) ─────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""

# ── WhatsApp button ───────────────────────────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER="250700000000"
